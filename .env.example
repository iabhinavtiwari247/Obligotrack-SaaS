# =============================================================
# ObligoTrack — Environment Variables
# Copy to .env and fill in values. NEVER commit .env to git.
# =============================================================

# ── Database ──────────────────────────────────────────────────
DB_USER=obligotrack
DB_PASSWORD=change_me_strong_password
DB_NAME=obligotrack
DATABASE_URL=postgresql://obligotrack:change_me_strong_password@localhost:5432/obligotrack

# ── Redis ─────────────────────────────────────────────────────
REDIS_URL=redis://localhost:6379

# ── JWT ───────────────────────────────────────────────────────
# Generate with: openssl rand -hex 64
JWT_SECRET=your_jwt_secret_here_min_64_chars
JWT_REFRESH_SECRET=your_refresh_secret_here_min_64_chars
JWT_EXPIRY=15m
JWT_REFRESH_EXPIRY=7d

# ── Razorpay (Indian Payments) ─────────────────────────────────
RAZORPAY_KEY_ID=rzp_live_xxxx
RAZORPAY_KEY_SECRET=your_razorpay_secret
RAZORPAY_WEBHOOK_SECRET=your_webhook_secret
# UPI VPA for direct settlements
RAZORPAY_VPA=tiwariabhinav273@okicici

# ── Stripe (International Payments) ────────────────────────────
STRIPE_SECRET_KEY=sk_live_xxxx
STRIPE_PUBLISHABLE_KEY=pk_live_xxxx
STRIPE_WEBHOOK_SECRET=whsec_xxxx

# ── Email (SMTP) ───────────────────────────────────────────────
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=notifications@obligotrack.com
SMTP_PASSWORD=your_app_specific_password
EMAIL_FROM="ObligoTrack <notifications@obligotrack.com>"

# ── URLs ───────────────────────────────────────────────────────
FRONTEND_URL=https://app.obligotrack.com
NEXT_PUBLIC_API_URL=https://api.obligotrack.com
